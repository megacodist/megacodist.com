{#-
  This template extends 'base.j2' to serve as License page for
  Megacodist Coding Blog.

  environment = {
  'app_name': # The name of the web application
  }

  No special context is needed.
-#}

{% extends 'base.j2' %}

{% block title %} Rock, Paper, Scissors - {{ super() }} {% endblock title %}

{% block style %}
  {{ super() }}
  div.game-div {
    padding: 20px;
  }
  div.player-div {
    width: 50%;
    float: left;
    padding: 20px;
    border: 2px solid red;
  }
{% endblock style %}

<style>
  #lplayer-info {
    justify-content: right;
  }
</style>

{% block main %}
  {{ super() }}
  <div id="alert-container"></div>
  <!-- The game info div -->
  <div class="game-div">
    <!-- Left player info div -->
    <div class="player-div border border-warning" id="lplayer-info">
      <!-- Selecting left player -->
      <div class="btn-group float-end" id="combo-lplayer">
        <button type="button" class="btn btn-outline-warning dropdown-toggle" id="lplayer-name" data-bs-toggle="dropdown" aria-expanded="false">
          Select left player
        </button>
        <ul class="dropdown-menu">
          <li><a class="dropdown-item" href="#">User</a></li>
          <li><a class="dropdown-item" href="#">Computer</a></li>
        </ul>
      </div>
    </div>
    <!-- Right player info div -->
    <div class="player-div border border-warning">
      <!-- Selecting player -->
      <div class="btn-group" id="combo-rplayer">
        <button type="button" class="btn btn-outline-warning dropdown-toggle" id="rplayer-name" data-bs-toggle="dropdown" aria-expanded="false">
          Select right player
        </button>
        <ul class="dropdown-menu">
          <li><a class="dropdown-item" href="#">User</a></li>
          <li><a class="dropdown-item" href="#">Computer</a></li>
        </ul>
      </div>
    </div>
    <form>
      <!-- Operations -->
      <div class="text-center p-2">
        <div class="btn-group" role="group" aria-label="Operations of Rock, Paper, Scissors game">
          <button type="button" class="btn btn-dark" id="pause">Pause</button>
          <button type="button" class="btn btn-dark" id="rock"><img src="{{ static('rock.png') }}" style="width: 40px;"></button>
          <button type="button" class="btn btn-dark" id="paper"><img src="{{ static('paper.png') }}" style="width: 40px;"></button>
          <button type="button" class="btn btn-dark" id="scissors"><input type="image" src="{{ static('scissors.png') }}" style="width: 40px;"></button>
          <button type="button" class="btn btn-dark" id="start-stop">Start</button>
        </div>
      </div>
    </form>
  </div>
  <section class="notes">
    <h6>Notes</h6>
    <ul>
      <li>
        The three images of rock, paper, and scissors are remixes of a
        <a href="https://www.freepik.com/free-vector/colourful-hands_1347305.htm">work</a>
        from
        <a href="https://www.freepik.com/author/brgfx">brgfx</a>
        .
      </li>
    </ul>
  </section>

{% endblock main %}

{%- block endingScripts %}
  {{ super() }}
  document.addEventListener(
    'DOMContentLoaded',
    function() {
      // Showing selected player in the dropdown...
      const dropdownMenus = document.querySelectorAll('.dropdown-menu');
      dropdownMenus.forEach((item) => {
        item.addEventListener(
          'click',
          (event) => {
            // Getting the selected player text...
            const selectedPlayer = event.target.textContent;
            const dropdownButton = item.previousElementSibling
            dropdownButton.textContent = selectedPlayer
          }
        )
      })
      // Disabling some buttons...
      document.getElementById('pause').disabled = true;
      document.getElementById('rock').disabled = true;
      document.getElementById('paper').disabled = true;
      document.getElementById('scissors').disabled = true;
      // Adding click handler for `start-stop` button...
      document.getElementById('start-stop').addEventListener(
        'click',
        onStartStopClicked
      );
    }
  );


  function onStartStopClicked() {
    // Checking if left player is selected...
    const lplayerName = document.getElementById('lplayer-name').textContent
    alert(lplayerName)
    if (lplayerName.startsWith('Select')) {
      alert('Please specify the left player.')
      showAlert('Please specify the left player.');
      return '';
    }
    //
    const btnStartStop = document.getElementById('start-stop')
    const mode = btnStartStop.textContent
    if (mode == 'Start') {
      btnStartStop.textContent = 'Stop'
      document.getElementById('pause').disabled = false;
      document.getElementById('rock').disabled = false;
      document.getElementById('paper').disabled = false;
      document.getElementById('scissors').disabled = false;
    } else if (mode == 'Stop') {
      btnStartStop.textContent = 'Start'
      document.getElementById('pause').disabled = true;
      document.getElementById('rock').disabled = true;
      document.getElementById('paper').disabled = true;
      document.getElementById('scissors').disabled = true;
    }
  }


  function showAlert(message, type = 'warning') {
    // Create the alert HTML
    const alertHTML = `
      <div class="alert alert-${type} alert-dismissible fade show custom-alert" role="alert">
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>`;
    // Append the alert to the body (or a container)
    document.getElementById('alert-container').innerHTML = alertHTML;
    // Optionally remove the alert after 5 seconds
    setTimeout(
      () => {
        document.querySelector('.custom-alert').remove();
      },
      5000 // 5000 milliseconds = 5 seconds
    );
}
{%- endblock endingScripts %}
