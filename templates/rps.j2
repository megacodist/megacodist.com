{% extends 'base.j2' %}

{% block title %} Challneges - {{ super() }} {% endblock title %}

{% block style %}
  {{ super() }}
  .game-div {
    border: 3px solid #fff;
    padding: 20px;
  }
  .player-div {
    width: 50%;
    float: left;
    padding: 20px;
    border: 2px solid red;
  }  
{% endblock style %}

{% block main %}
  {{ super() }}
