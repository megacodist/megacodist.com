{#-
  The ultimate base skeleton for the entire Megacodist web site, so it
  does not extend any template.

  environment = {
  'app_name': # The name of the web application
  }

  No special context is needed.
-#}


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <!-- If you are going to target IE8 & IE9, uncomment the following tag (it must be as close to the top of HEAD element as you can)...
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  -->
  <meta http-equiv="content-type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# Setting the 'favicon.ico' #}
  <link rel="shortcut icon" href="{{  static('img/favicon.ico') }}">

  <title>
    {%- block title %}{{app_name}}{% endblock title -%}
  </title>

  {%- block head -%}
    {#- First part of enabling Bootstrap framework... #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">

    {#- Linking Font Awesome icon library for the entire Megacodist web site... #}
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v6.5.1/css/all.css">

    {#- Linking the 'base.css'... #}
    <link rel="stylesheet" href="{{ static('css/base.css') }}">

    <!-- [if lt IE 9]>
      <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
      <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <! [endif]-->
  {%- endblock head %}

  <style>
    {%- block style %}
    {%- endblock style %}
  </style>
</head>
<body>
  {#- Including header --------------------------------------------------------------------------------- #}
  {%- include 'header.j2' %}

  <main class="main">
    {% block main %}
    {% endblock main %}
  </main>

  {# Including footer---------------------------------------------------------------------------------- #}
  {%- include 'footer.j2' -%}

  {# A reserved region for some HTML elements such as modal boxes ------------------------------------- #}
  {% block EndingReservedTags %}
  {% endblock %}

  {# Including JS files at the end of page ------------------------------------------------------------- #}
  {% block jsFiles %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
  {% endblock %}

  {# Including JS scripts the end of page -------------------------------------------------------------- #}
  {%- block jsScripts %}
    {#- Enabling Box Icons icon library -#}
    <script src="https://unpkg.com/boxicons@2.1.4/dist/boxicons.js"></script>
  {%- endblock jsScripts %}
</body>
</html>